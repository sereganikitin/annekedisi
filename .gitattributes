* text=auto eol=lf

# These types are always shipped to a Linux server — force LF regardless of
# the developer's autocrlf setting.
*.sh           text eol=lf
*.service      text eol=lf
*.conf         text eol=lf
*.example      text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.json         text eol=lf
*.css          text eol=lf
*.html         text eol=lf
*.md           text eol=lf

# Binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.woff         binary
*.woff2        binary
